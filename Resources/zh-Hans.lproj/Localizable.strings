/* Menu */
"Keeps your Mac awake while your coding agents work." = "在编码代理工作时让你的 Mac 保持唤醒。";
"On battery — plug in for long runs" = "正在使用电池——长时间运行请接通电源";
"Lid-closed needs a one-time approval" = "合盖模式需要一次性授权";
"Always keep awake" = "始终保持唤醒";
