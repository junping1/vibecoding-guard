/* Status (menu header) */
"%@ is working" = "%@ が作業中";
"Keeping your Mac awake" = "Mac をスリープさせていません";
"Standing by" = "待機中";
"Your Mac will stay awake." = "Mac はスリープしません。";
"Sleeps normally. I wake up automatically when an agent runs." = "通常どおりスリープします。エージェントが動き出すと自動的に起動します。";
"Always on, until you turn it off." = "オフにするまで、ずっとオンのままです。";
"Starting…" = "起動中…";
"Cooling down" = "冷却中";
"Paused lid-closed work to cool down." = "冷却のため蓋を閉じた作業を一時停止しました。";

/* Menu */
"Keeps your Mac awake while your coding agents work." = "コーディングエージェントの作業中、Mac をスリープさせません。";
"On battery — plug in for long runs" = "バッテリー駆動中 — 長時間の実行は電源を接続してください";
"Lid-closed needs a one-time approval" = "蓋を閉じたモードには一度きりの承認が必要です";
"Always keep awake" = "常にスリープさせない";
"Keyboard Lock" = "キーボードロック";
"Keep running with lid closed" = "蓋を閉じても実行を継続";
"Settings…" = "設定…";
"Quit" = "終了";
"Allow Keyboard Permission..." = "キーボードの権限を許可...";
"Open Accessibility Settings..." = "アクセシビリティ設定を開く...";

/* Welcome */
"I live in the menu bar and keep your Mac awake while Codex or Claude Code are working — then let it sleep when they stop.\n\nThere's nothing to set up. Look for the bolt in the menu bar." = "私はメニューバーに常駐し、Codex または Claude Code の作業中は Mac をスリープさせず、作業が終わるとスリープを許可します。\n\n設定は不要です。メニューバーの稲妻アイコンを探してください。";

/* About manual */
"Keeps your Mac awake so long coding jobs finish while you're away." = "Mac をスリープさせず、離席中でも長いコーディング作業が完了するようにします。";
"How it works" = "仕組み";
"It's automatic" = "全自動";
"While Codex or Claude Code are working, your Mac stays awake. When they finish, it sleeps as usual. You don't have to do anything." = "Codex または Claude Code の作業中は Mac がスリープしません。作業が終わると通常どおりスリープします。何もする必要はありません。";
"Turn this on to keep your Mac awake no matter what, until you turn it off." = "これをオンにすると、オフにするまで Mac を常にスリープさせません。";
"Blocks the keyboard during a run so a pet or child can't interrupt it. Press ⌘⌥⌃L to unlock." = "実行中にキーボードをロックし、ペットや子どもが邪魔できないようにします。⌘⌥⌃L で解除できます。";
"Keep working with the lid shut. Use it on a desk only — it pauses if your Mac gets too hot." = "蓋を閉じたまま作業を続けられます。デスク上でのみ使用してください — 熱くなりすぎると一時停止します。";

/* Settings panel */
"Battery" = "バッテリー";
"Low battery warning" = "バッテリー残量の警告";
"Off" = "オフ";
"Notification banners" = "通知バナー";
"Optional. Sound alerts still work without banners." = "オプション。バナーがなくても音声警告は機能します。";
"Test alert sound" = "警告音のテスト";
"Test" = "テスト";
"Display" = "ディスプレイ";
"Turn off screen after" = "画面をオフにするまで";
"Never" = "しない";
"3 minutes" = "3分";
"5 minutes" = "5分";
"10 minutes" = "10分";
"15 minutes" = "15分";
"Lid closed" = "蓋を閉じる";
"Run this only with your Mac on a desk. In a bag it can't shed heat and may overheat. It pauses on its own if it gets too hot, but don't rely on that." = "Mac をデスク上に置いているときだけ使用してください。バッグの中では熱を逃がせず、過熱するおそれがあります。熱くなりすぎると自動的に一時停止しますが、それに頼らないでください。";
"Turn off lid-closed and remove its admin access." = "蓋を閉じたモードを無効にし、その管理者権限を削除します。";
"Remove" = "削除";

/* Button states */
"Allow" = "許可";
"Open Settings" = "設定を開く";
"Not Set" = "未設定";

/* Lid-closed failure */
"Lid-closed mode not enabled" = "蓋を閉じたモードは有効になっていません";
"It needs a one-time admin approval. Try again when you're ready." = "一度きりの管理者承認が必要です。準備ができたら再度お試しください。";

/* Thermal back-off */
"Your Mac is getting warm, so I paused lid-closed work to protect it. It resumes automatically once it cools." = "Mac が熱くなってきたので、保護のため蓋を閉じた作業を一時停止しました。冷えると自動的に再開します。";

/* Keyboard lock notification */
"Keyboard locked" = "キーボードをロックしました";
"Vibe Coding Guard is blocking the keyboard. Press ⌘⌥⌃L to unlock." = "Vibe Coding Guard がキーボードをブロックしています。⌘⌥⌃L を押すと解除できます。";

/* Agent detail */
"tool session" = "ツールセッション";
"task" = "タスク";
"work" = "作業";

/* Battery alerts / system notifications */
"Battery low" = "低バッテリー";
"Battery is at %d percent. Please plug in power." = "バッテリー残量が %d%% です。電源を接続してください。";
"Battery is getting low. Plug in your charger." = "バッテリーが減ってきました。充電器を接続してください。";
"Battery is almost dead. Plug in now." = "バッテリーがほとんどありません。今すぐ電源を接続してください。";
"Vibe Coding Guard test" = "Vibe Coding Guard テスト";
"Battery warnings are ready." = "バッテリー警告は正常に機能しています。";
"This is a test. Alerts are working." = "テストです。警告は正常に動作しています。";

