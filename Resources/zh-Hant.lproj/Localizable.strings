"Battery" = "電池";
"Low battery warning" = "低電量提醒";
"Off" = "關閉";
"Notification banners" = "通知橫幅";
"Optional. Sound alerts still work without banners." = "可選。即使沒有橫幅，聲音警報仍會運作。";
"Test alert sound" = "測試警報聲音";
"Test" = "測試";
"Display" = "顯示器";
